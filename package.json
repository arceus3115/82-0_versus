{
  "name": "versus",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "data:build": "node scripts/build-players.mjs",
    "dev": "vite",
    "peer-server": "node scripts/peer-server.mjs",
    "dev:online": "concurrently -k \"npm:peer-server\" \"npm:dev\"",
    "build": "npm run data:build && npm run typecheck && vite build",
    "preview": "vite preview",
    "prepare": "husky",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src scripts",
    "lint:fix": "eslint src scripts --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run typecheck && npm run lint && npm run format:check"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,json,md,yml,yaml,js,mjs}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "peerjs": "^1.5.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "peer": "^1.0.2",
    "prettier": "^3.8.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^6.3.5"
  }
}
