{
  "name": "versus",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "data:build": "node scripts/build-players.mjs",
    "dev": "vite",
    "peer-server": "node scripts/peer-server.mjs",
    "dev:online": "concurrently -k \"npm:peer-server\" \"npm:dev\"",
    "build": "npm run data:build && tsc --noEmit && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "peerjs": "^1.5.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "peer": "^1.0.2",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  }
}
