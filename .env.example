# Online mode (production build) — point at your deployed PeerJS signaling server.
# Deploy scripts/peer-server.mjs (see render.yaml or README).
VITE_PEER_HOST=your-peer-server.onrender.com
VITE_PEER_PORT=443
VITE_PEER_PATH=/
VITE_PEER_SECURE=true

# GitHub Pages base path override (optional — auto-detected from GITHUB_REPOSITORY in CI)
# PAGES_BASE=versus
